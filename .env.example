# Node.js version used in server and client Dockerfiles (node:<version>-slim)
NODE_VERSION=18-slim

# MongoDB version used in docker-compose.yml (mongo:<version>)
MONGO_VERSION=7

# MongoDB credentials and database name
MONGO_ROOT_USER=root
MONGO_ROOT_PASS=change_me_password
MONGO_DB=promptdb

# Frontend API URL (baked into JS at build time)
VITE_API_URL=http://localhost:3000/api
